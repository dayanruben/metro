{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
  ],
  ignorePresets: [
    // Ensure we get the latest version and are not pinned to old versions.
    'workarounds:javaLTSVersions',
  ],
  customManagers: [
    // Update .java-version file with the latest JDK version.
    {
      customType: 'regex',
      fileMatch: [
        '\\.java-version$',
      ],
      matchStrings: [
        '(?<currentValue>.*)\\n',
      ],
      datasourceTemplate: 'java-version',
      depNameTemplate: 'java',
      // Only write the major version.
      extractVersionTemplate: '^(?<version>\\d+)',
    },
    // Track jdk = "..." in libs.versions.toml.
    {
      customType: 'regex',
      fileMatch: ['gradle/libs\\.versions\\.toml'],
      matchStrings: ['^jdk\\s*=\\s*"(?<currentValue>\\d+)"'],
      datasourceTemplate: 'java-version',
      depNameTemplate: 'java',
      extractVersionTemplate: '^(?<version>\\d+)',
    },
    // Track ktfmt version pinned in .kempt.toml.
    // The `[^\\[]*?` lookahead keeps the match within the [ktfmt] section.
    {
      customType: 'regex',
      fileMatch: ['(^|/)\\.kempt\\.toml$'],
      matchStrings: [
        '\\[ktfmt\\][^\\[]*?version\\s*=\\s*"(?<currentValue>[^"]+)"',
      ],
      datasourceTemplate: 'maven',
      registryUrlTemplate: 'https://repo1.maven.org/maven2',
      depNameTemplate: 'com.facebook:ktfmt',
    },
    // Track google-java-format version pinned in .kempt.toml.
    {
      customType: 'regex',
      fileMatch: ['(^|/)\\.kempt\\.toml$'],
      matchStrings: [
        '\\[gjf\\][^\\[]*?version\\s*=\\s*"(?<currentValue>[^"]+)"',
      ],
      datasourceTemplate: 'maven',
      registryUrlTemplate: 'https://repo1.maven.org/maven2',
      depNameTemplate: 'com.google.googlejavaformat:google-java-format',
    },
  ],
  packageRules: [
    // Group rules first; disables come after so they win on overlap.
    {
      groupName: 'JDK version',
      matchDepNames: ['java'],
      matchDatasources: ['java-version'],
    },
    {
      groupName: 'AGP',
      matchDepNames: [
        'com.android.application',
        'com.android.library',
        'com.android.lint',
        'com.android.settings',
        'com.android.test',
      ],
    },
    {
      description: 'Disable Kotlin updates - manually managed due to compiler plugin compatibility',
      enabled: false,
      matchPackageNames: [
        '/^org\\.jetbrains\\.kotlin/',
      ],
    },
    {
      description: 'Disable Android Gradle Plugin updates - manually managed',
      enabled: false,
      matchPackageNames: [
        'com.android.lint',
        'com.android.library',
        'com.android.application',
      ],
    },
  ],
}
